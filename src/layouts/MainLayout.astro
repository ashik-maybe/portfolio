---
import "../styles/global.css";

interface Props {
    title?: string;
    layoutSize?: "standard" | "wide" | "editorial";
    centered?: boolean;
    noScanlines?: boolean;
}

const { title = "ASHIK", layoutSize = "standard", centered = false, noScanlines = false } = Astro.props;

const widthClasses = {
    standard: "w-full sm:max-w-lg lg:max-w-xl",
    wide: "w-full sm:max-w-2xl lg:max-w-4xl",
    editorial: "w-full sm:max-w-2xl lg:max-w-4xl xl:max-w-5xl",
};

const selectedWidth = widthClasses[layoutSize];
---

<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>

        <style is:global>
            /* Persona 5 Halftone Background Dots Matrix Pattern */
            .p5-bg {
                background-color: #009639;
                background-image:
                    radial-gradient(rgba(0, 0, 0, 0.18) 15%, transparent 16%),
                    radial-gradient(rgba(0, 0, 0, 0.18) 15%, transparent 16%);
                background-size: 16px 16px;
                background-position:
                    0 0,
                    8px 8px;
            }

            /* Structural Utility Transforms */
            .skew-p5-left {
                transform: skewX(-12deg);
            }
            .skew-p5-right {
                transform: skewX(8deg);
            }

            /* Slow spin animation loop for the background decorative nodes */
            @keyframes spin-slow {
                0% {
                    transform: rotate(0deg);
                }
                100% {
                    transform: rotate(360deg);
                }
            }
            .p5-shape-spin {
                animation: spin-slow 80s linear infinite;
            }
        </style>
    </head>
    <body
        class="p5-bg text-black font-sans min-h-screen flex flex-col relative overflow-x-hidden p-4 sm:p-6 md:p-8 pb-24 selection:bg-black selection:text-[#009639]"
    >
        <!-- Background Texture Stripes Layer (Scale matches viewport ratios) -->
        <div
            class="absolute inset-0 bg-[linear-gradient(45deg,rgba(0,0,0,0.02)_25%,transparent_25%,transparent_50%,rgba(0,0,0,0.02)_50%,rgba(0,0,0,0.02)_75%,transparent_75%,transparent)] bg-[length:60px_60px] sm:bg-[length:100px_100px] pointer-events-none z-0"
        >
        </div>

        <!-- Background Crescent Moon Accent -->
        <div
            class="absolute -top-32 -left-32 w-[350px] h-[350px] sm:w-[550px] sm:h-[550px] md:w-[750px] md:h-[750px] text-black opacity-[0.07] p5-shape-spin pointer-events-none -z-10 select-none"
        >
            <svg viewBox="0 0 100 100" fill="currentColor" width="100%" height="100%">
                <path d="M 50,5 A 45,45 0 1,0 95,50 A 37,37 0 1,1 50,5 Z"></path>
            </svg>
        </div>

        <div class="flex-1 flex flex-col w-full">
            <div
                class="w-full max-w-xl mx-auto mt-2 sm:mt-6 md:mt-10 transition-all duration-p5 ease-p5"
            >
                <slot name="nav" />
            </div>

            <div class={`flex-1 flex flex-col ${centered ? 'justify-center' : 'justify-start'} w-full ${selectedWidth} mx-auto`}>
                <main class="w-full clear-both mt-2 sm:mt-4 animate-p5-enter">
                    <slot />
                </main>
            </div>
        </div>

        {!noScanlines && <div class="p5-scanlines"></div>}

        <script>
            const el = document.querySelector(".p5-shape-spin");
            if (el) el.style.animationDelay = `-${Math.random() * 80}s`;
        </script>
    </body>
</html>
