---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import Navigation from "../../components/Navigation.astro";

// Fetch entries from the 'blog' collection
const posts = (await getCollection("blog")).sort((a, b) => b.data.date.localeCompare(a.data.date));
const base = import.meta.env.BASE_URL;
---

<MainLayout title="Blog" layoutSize="wide">
    <Navigation slot="nav" />

    <header class="mb-10 transform -rotate-1 select-none">
        <h1 class="bg-white text-black border-4 border-black text-3xl sm:text-4xl font-black uppercase tracking-tighter px-4 py-2 inline-block skew-p5-right shadow-[5px_5px_0px_#000]">
            BLOG
        </h1>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 w-full">
        {
            posts.length === 0 ? (
                <div class="animate-p5-enter bg-white border-4 border-black p-5 shadow-[6px_6px_0px_#000] text-center font-mono text-sm font-bold col-span-full">
                    // NO POSTS YET.
                </div>
            ) : (
                posts.map((post, idx) => {
                    const artRotate = idx % 2 === 0 ? "-rotate-1" : "rotate-1";
                    return (
                    <article class={`animate-p5-enter p5-corners bg-white text-black border-4 border-black p-5 shadow-[6px_6px_0px_#000] relative group ${artRotate} hover:-translate-y-1 hover:rotate-0 transition-all duration-p5 ease-p5`} style={`animation-delay: ${idx * 60}ms`}>
                        <div class="flex items-center justify-between font-mono text-[11px] font-bold text-zinc-500 mb-2">
                            <span>// {post.data.date}</span>
                            <div class="flex gap-2">
                                {post.data.tags?.map((tag) => (
                                    <span class="bg-zinc-100 text-black border border-black px-1.5 py-0.5 text-[9px] uppercase tracking-wide">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </div>

                        <h2 class="text-xl font-black uppercase tracking-tight group-hover:text-[#009639] transition-colors duration-p5 ease-p5 mb-2 leading-snug">
                            <a href={`${base}blog/${post.id}`} class="focus:outline-none">
                                {post.data.title}
                            </a>
                        </h2>

                        <p class="text-zinc-700 text-xs sm:text-sm font-medium leading-relaxed mb-4">
                            {post.data.description}
                        </p>

                        <a
                            href={`${base}blog/${post.id}`}
                            class="inline-flex items-center gap-1 font-mono font-black text-xs uppercase text-[#009639] hover:text-black transition-colors duration-p5 ease-p5"
                        >
                            READ <span class="text-black font-sans">→</span>
                        </a>
                    </article>
                    );
                })
            )
        }
    </div>
</MainLayout>
