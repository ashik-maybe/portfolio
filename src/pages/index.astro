---
import MainLayout from "../layouts/MainLayout.astro";
import Navigation from "../components/Navigation.astro";
import P5Button from "../components/P5Button.astro";
import P5Card from "../components/P5Card.astro";

const name = "ASHIK";
const pronunciation = "ah-SHEEK /ɑːʃiːk/";
const interests = ["Linux", "Git", "Python", "TypeScript"];
const githubUrl = "https://github.com/ashik-maybe/";
const linkedinUrl = "https://www.linkedin.com/in/ashik-md/";
---

<MainLayout title={`${name}`} centered>
    <Navigation slot="nav" />

    <!-- FIXED HEADER LAYER OVERLAPS -->
    <header class="relative mb-14 transform -rotate-2 select-none inline-block">
        <div
            class="absolute top-1.5 left-1.5 bg-black text-transparent text-4xl sm:text-6xl font-black uppercase tracking-tighter px-4 sm:px-6 py-2 skew-p5-left whitespace-nowrap"
        >
            HELLO, I'M {name}
        </div>
        <h1
            class="relative bg-white text-black text-4xl sm:text-6xl font-black uppercase tracking-tighter px-4 sm:px-6 py-2 border-4 border-black skew-p5-left inline-block shadow-[6px_6px_0px_#000] whitespace-nowrap"
        >
            HELLO, I'M <span
                class="text-[#009639] bg-black px-2 sm:px-3 py-0.5 ml-1 inline-block transform rotate-2"
                >{name}</span
            >
        </h1>

        <div class="block mt-4 transform rotate-1">
            <p
                class="inline-block bg-black text-white font-mono text-[10px] sm:text-xs uppercase px-3 py-1 font-bold border-2 border-white tracking-widest skew-p5-right shadow-[4px_4px_0px_#009639]"
            >
                {pronunciation}
            </p>
        </div>
    </header>

    <!-- INTERESTS GRID FLUID CONTAINER -->
    <section class="grid grid-cols-2 gap-4 w-full max-w-sm mx-auto mb-8">
        {
            interests.map((skill, index) => {
                const rotation = index % 2 === 0 ? "-rotate-1" : "rotate-2";
                return <P5Card label={skill} index={index} class={rotation} />;
            })
        }
    </section>

    <!-- FOOTER WITH BRAND LINKS -->
    <footer
        class="flex flex-wrap gap-4 justify-start items-center pt-10 border-t-4 border-black relative"
    >
        <div class="absolute -top-3 left-0 w-full h-1 bg-black transform -rotate-1"></div>
        <div class="absolute -top-3 left-0 w-full h-1 bg-black transform rotate-1"></div>

        <P5Button
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            variant="black"
            class="hover:bg-[#24292e]"
        >
            GitHub
        </P5Button>

        <P5Button
            href={linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            variant="white"
            class="hover:bg-[#0077b5] hover:text-white"
        >
            LinkedIn
        </P5Button>
    </footer>
</MainLayout>
