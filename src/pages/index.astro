---
import "../styles/global.css";
const name = "ASHIK";
const pronunciation = "ah-SHEEK /ɑːʃiːk/";
const interests = ["Linux", "Git", "Python", "TypeScript"];
const githubUrl = "https://github.com/ashik-maybe/";
const linkedinUrl = "https://www.linkedin.com/in/ashik-md/";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{name} // Profile</title>
        <style is:global>
            /* Persona 5 Halftone Dot Background Pattern */
            .p5-bg {
                background-color: #e60012;
                background-image:
                    radial-gradient(rgba(0, 0, 0, 0.15) 15%, transparent 16%),
                    radial-gradient(rgba(0, 0, 0, 0.15) 15%, transparent 16%);
                background-size: 16px 16px;
                background-position:
                    0 0,
                    8px 8px;
            }

            .skew-p5-left {
                transform: skewX(-12deg);
            }
            .skew-p5-right {
                transform: skewX(8deg);
            }

            @keyframes spin-slow {
                0% {
                    transform: rotate(0deg);
                }
                100% {
                    transform: rotate(360deg);
                }
            }
            .p5-star-spin {
                animation: spin-slow 50s linear infinite;
            }
        </style>
    </head>
    <body
        class="p5-bg text-black font-sans min-h-screen flex items-center justify-center p-4 relative overflow-hidden selection:bg-black selection:text-[#e60012]"
    >
        <!-- Background Graphic Elements -->
        <div
            class="absolute inset-0 bg-[linear-gradient(45deg,rgba(0,0,0,0.05)_25%,transparent_25%,transparent_50%,rgba(0,0,0,0.05)_50%,rgba(0,0,0,0.05)_75%,transparent_75%,transparent)] bg-[length:100px_100px] pointer-events-none"
        >
        </div>
        <div
            class="absolute -top-20 -left-20 w-[600px] h-[600px] bg-black opacity-10 p5-star-spin pointer-events-none -z-10"
            style="clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);"
        >
        </div>

        <main class="w-full max-w-xl relative z-10 p-4">
            <!-- HEADER SECTION -->
            <header class="relative mb-12 transform -rotate-3 select-none">
                <div
                    class="absolute top-2 left-2 bg-black text-transparent text-6xl font-black uppercase tracking-tighter px-6 py-2 skew-p5-left"
                >
                    {name}
                </div>
                <h1
                    class="relative bg-white text-black text-6xl font-black uppercase tracking-tighter px-6 py-2 border-4 border-black skew-p5-left inline-block shadow-[8px_8px_0px_#000]"
                >
                    HELLO, I'M <span
                        class="text-[#e60012] bg-black px-3 py-1 ml-1 inline-block transform rotate-2"
                        >{name}</span
                    >
                </h1>

                <!-- Cleaned up pronunciation sub-badge -->
                <div class="block mt-4 transform rotate-2">
                    <p
                        class="inline-block bg-black text-white font-mono text-xs uppercase px-4 py-1.5 font-bold border-2 border-white tracking-widest skew-p5-right shadow-[4px_4px_0px_#e60012]"
                    >
                        {pronunciation}
                    </p>
                </div>
            </header>

            <!-- SKILLS / INTERESTS SECTION -->
            <section class="mb-14 space-y-4 max-w-sm pl-4">
                {
                    interests.map((skill, index) => {
                        const isEven = index % 2 === 0;
                        const rotation = isEven ? "-rotate-2" : "rotate-3";
                        const translation = isEven ? "hover:translate-x-6" : "hover:translate-x-4";
                        const bgClass = isEven ? "bg-black text-white" : "bg-white text-black";

                        return (
                            <div
                                class={`transform ${rotation} ${translation} transition-all duration-200 cursor-pointer group relative`}
                            >
                                <div class="absolute inset-0 bg-[#e60012] opacity-0 group-hover:opacity-100 group-hover:translate-x-2 group-hover:translate-y-1 transition-all duration-150 border-2 border-black" />
                                <div
                                    class={`relative px-6 py-3 border-4 border-black ${bgClass} font-black text-xl tracking-wider uppercase flex items-center justify-between shadow-[6px_6px_0px_rgba(0,0,0,0.3)]`}
                                >
                                    <span class="flex items-center gap-3">
                                        <span class="text-[#e60012] font-mono text-sm">
                                            // 0{index + 1}
                                        </span>
                                        {skill}
                                    </span>
                                    <span class="text-xl opacity-0 group-hover:opacity-100 transform group-hover:translate-x-1 transition-all">
                                        ★
                                    </span>
                                </div>
                            </div>
                        );
                    })
                }
            </section>

            <!-- FOOTER LINKS -->
            <footer
                class="flex flex-wrap gap-6 justify-start items-center pt-6 border-t-4 border-black relative"
            >
                <div class="absolute -top-3 left-0 w-full h-2 bg-black transform -rotate-1"></div>

                <a
                    href={githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="transform -rotate-6 hover:rotate-0 hover:scale-105 bg-black text-white hover:bg-white hover:text-black border-4 border-black font-black text-base uppercase px-6 py-2.5 tracking-tight shadow-[5px_5px_0px_#fff] hover:shadow-[5px_5px_0px_#000] transition-all duration-150"
                >
                    GitHub
                </a>

                <a
                    href={linkedinUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="transform rotate-3 hover:rotate-0 hover:scale-105 bg-[#e60012] text-white hover:bg-black border-4 border-black font-black text-base uppercase px-6 py-2.5 tracking-tight shadow-[5px_5px_0px_#000] transition-all duration-150"
                >
                    LinkedIn
                </a>
            </footer>
        </main>
    </body>
</html>
