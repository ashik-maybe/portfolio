---
import "../styles/global.css";
const name = "ASHIK";
const pronunciation = "ah-SHEEK /ɑːʃiːk/";
const interests = ["Linux", "Git", "Python", "TypeScript"];
const githubUrl = "https://github.com/ashik-maybe/";
const linkedinUrl = "https://www.linkedin.com/in/ashik-md/";

const accentColor = "bg-[#A3E635]";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{name} | Portfolio</title>
        <style is:global>
            /* Custom Neo-Brutalist Animations */
            @keyframes jitter {
                0% {
                    transform: translate(0, 0);
                }
                25% {
                    transform: translate(-2px, 2px);
                }
                50% {
                    transform: translate(2px, -2px);
                }
                75% {
                    transform: translate(-1px, -1px);
                }
                100% {
                    transform: translate(1px, 1px);
                }
            }

            @keyframes marquee {
                0% {
                    transform: translateX(0);
                }
                100% {
                    transform: translateX(-50%);
                }
            }

            .animate-jitter:hover {
                animation: jitter 0.2s infinite;
            }

            .marquee-content {
                display: flex;
                animation: marquee 20s linear infinite;
            }
        </style>
    </head>
    <body
        class="bg-[#F1F5F9] text-black font-mono min-h-screen flex items-center justify-center p-4 overflow-x-hidden"
    >
        <main
            class="max-w-2xl w-full p-8 bg-white border-4 border-black shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] hover:shadow-[16px_16px_0px_0px_rgba(0,0,0,1)] transition-all duration-75"
        >
            <header class="mb-10 relative">
                <!-- Decorative background element -->
                <div
                    class="absolute -top-4 -right-4 w-12 h-12 bg-orange-400 border-2 border-black -z-10 animate-bounce"
                >
                </div>

                <h1 class="text-6xl font-black uppercase tracking-tighter mb-2 cursor-pointer">
                    Hey, I'm <span
                        class={`${accentColor} px-2 border-2 border-black inline-block animate-jitter`}
                        >{name}</span
                    >
                </h1>
                <p class="text-xl font-bold uppercase underline decoration-4 decoration-black">
                    Pronounced: {pronunciation}
                </p>
            </header>

            <!-- Marquee Interests Section -->
            <section class="mb-10 overflow-hidden border-y-4 border-black bg-yellow-300 -mx-8 py-2">
                <div class="marquee-content whitespace-nowrap flex gap-8">
                    {
                        [...interests, ...interests].map((skill) => (
                            <span class="text-xl font-black uppercase flex items-center gap-2">
                                {skill} <span class="text-2xl">★</span>
                            </span>
                        ))
                    }
                </div>
            </section>

            <section class="mb-10">
                <h2
                    class="text-2xl font-black uppercase mb-6 bg-white inline-block px-4 py-1 border-2 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]"
                >
                    Stack
                </h2>
                <div class="grid grid-cols-2 gap-4">
                    {
                        interests.slice(0, 4).map((skill) => (
                            <div class="p-4 bg-white border-2 border-black font-bold shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all cursor-crosshair group">
                                <span class="group-hover:text-blue-600 transition-colors">
                                    {skill}
                                </span>
                            </div>
                        ))
                    }
                </div>
            </section>

            <footer class="flex flex-wrap gap-6 border-t-4 border-black pt-8">
                <a
                    href={githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 px-6 py-3 bg-blue-400 border-2 border-black font-black uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[4px] active:translate-y-[4px] transition-all"
                >
                    GitHub
                </a>

                <a
                    href={linkedinUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 px-6 py-3 bg-pink-400 border-2 border-black font-black uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[4px] active:translate-y-[4px] transition-all"
                >
                    LinkedIn
                </a>
            </footer>
        </main>
    </body>
</html>
